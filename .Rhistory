# Gráfico de Contornos (Círculos de densidad) - Versión Limpia para Póster
ggplot(datos, aes(x = Rings, y = Shucked)) +
# 1. Los puntos de fondo muy claritos para dar contexto sin molestar
geom_point(alpha = 0.1, size = 0.5, color = "gray") +
# 2. Las líneas de contorno (los círculos)
geom_density_2d(linewidth = 0.5, bins = 10, aes(color = after_stat(level))) +
# 3. Escala de colores degradada (puedes usar "viridis" para que sea profesional)
scale_color_viridis_c(option = "viridis") +
# 4. Limitar ejes para que no sobre espacio en blanco
scale_x_continuous(limits = c(0, 25)) +
scale_y_continuous(limits = c(0, 1.2)) +
labs(title = "Relación Edad vs Peso: Curvas de Densidad",
subtitle = "Los círculos concéntricos muestran la mayor probabilidad de encontrar ejemplares",
x = "Número de Anillos (Edad)",
y = "Peso de la Carne (g)",
color = "Nivel") +
theme_minimal() +
theme(legend.position = "right")
