# Polígono de Densidad 2D Mejorado (Mapa de Calor de Alta Claridad)
ggplot(datos, aes(x = Rings, y = Shucked)) +
# Usamos 'stat_density_2d' con relleno para un efecto más suave
stat_density_2d(aes(fill = after_stat(level)), geom = "polygon", bins = 15, alpha = 0.8) +
# Añadimos una paleta de colores vibrante (Magma o Inferno)
scale_fill_viridis_c(option = "magma") +
# Limitamos los ejes para centrar la vista en el grueso de los datos
xlim(0, 20) +
ylim(0, 1.2) +
labs(title = "Densidad de Población: Edad vs Peso de la Carne",
subtitle = "La zona amarilla indica la mayor concentración comercial",
x = "Número de Anillos (Edad)",
y = "Peso de la Carne (g)",
fill = "Densidad") +
theme_minimal() +
theme(panel.grid.minor = element_blank()) # Limpiamos el fondo para que resalte el color
ggplot(datos, aes(x = Rings, y = Shucked)) +
# Usamos 'stat_density_2d' con relleno para un efecto más suave
stat_density_2d(aes(fill = after_stat(level)), geom = "polygon", bins = 15, alpha = 0.8) +
# Añadimos una paleta de colores vibrante (Magma o Inferno)
scale_fill_viridis_c(option = "magma") +
# Limitamos los ejes para centrar la vista en el grueso de los datos
xlim(0, 20) +
ylim(0, 1.2) +
labs(title = "Densidad de Población: Edad vs Peso de la Carne",
subtitle = "La zona amarilla indica la mayor concentración comercial",
x = "Número de Anillos (Edad)",
y = "Peso de la Carne (g)",
fill = "Densidad") +
theme_minimal() +
theme(panel.grid.minor = element_blank()) # Limpiamos el fondo para que resalte el color
ggplot(datos, aes(x = Rings, y = Shucked)) +
geom_bin2d(bins = 40) + # Ajustamos a 40 para que los cuadrados sean pequeños y definidos
# Usamos la escala 'inferno' que va de negro a amarillo brillante
scale_fill_viridis_c(option = "inferno") +
# Limpiamos los límites para que no se vea vacío por los bordes
scale_x_continuous(limits = c(0, 25), breaks = seq(0, 25, 5)) +
scale_y_continuous(limits = c(0, 1.0)) +
labs(title = "Análisis de Densidad Comercial: Edad vs Peso de la Carne",
subtitle = "La intensidad del brillo indica la concentración de la población",
x = "Número de Anillos (Edad)",
y = "Peso de la Carne (Shucked Weight en g)",
fill = "Conteo") +
theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 14),
panel.grid.major = element_line(color = "gray90"),
legend.position = "right"
